{
  "name": "actual-expo",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "ios": "APP_VARIANT=development expo run:ios",
    "ios:prod": "expo run:ios",
    "prebuild:dev": "APP_VARIANT=development npx expo prebuild --clean",
    "prebuild:prod": "npx expo prebuild --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:preview": "eas build --profile preview --platform ios --local --non-interactive",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "e2e": "maestro test maestro/",
    "e2e:flow": "maestro test",
    "prepare": "husky"
  },
